{
  "name": "vite-plugin-froede",
  "version": "0.5.1",
  "description": "Vite plugin that annotates JSX elements with their source location during dev, so the froede extension can map clicks back to real code.",
  "license": "MIT",
  "author": "Mun1to",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mun1to/froede.git",
    "directory": "packages/vite-plugin"
  },
  "homepage": "https://github.com/Mun1to/froede#readme",
  "bugs": "https://github.com/Mun1to/froede/issues",
  "keywords": [
    "vite-plugin",
    "froede",
    "visual-editor",
    "jsx",
    "devtools"
  ],
  "peerDependencies": {
    "vite": ">=4"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "magic-string": "^0.30.0"
  }
}
